<Window x:Class="MoodTracker.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MoodTracker"
        Width="1040"
        Height="760"
        MinWidth="920"
        MinHeight="680"
        Background="#0F0F18"
        FontFamily="Segoe UI">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="18" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="#16161F"
            BorderBrush="#28283A"
            BorderThickness="1"
            CornerRadius="14"
            Padding="20">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2.1*" />
          <ColumnDefinition Width="18" />
          <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock Text="MOODTRACKER"
                     Foreground="#6C63FF"
                     FontSize="14"
                     FontWeight="Bold" />
          <TextBlock x:Name="DateTextBlock"
                     Margin="0,6,0,0"
                     Foreground="#A6A6BF"
                     FontSize="13" />

          <StackPanel Orientation="Horizontal" Margin="0,22,0,0" VerticalAlignment="Center">
            <TextBlock x:Name="EmojiTextBlock"
                       Width="68"
                       Text="😐"
                       FontSize="42"
                       VerticalAlignment="Center" />
            <StackPanel>
              <TextBlock x:Name="ValueTextBlock"
                         Text="0"
                         FontSize="48"
                         FontWeight="Bold"
                         Foreground="#EEEEFC" />
              <TextBlock x:Name="DescriptionTextBlock"
                         Margin="2,2,0,0"
                         Text="Neutral"
                         FontSize="15"
                         Foreground="#A6A6BF" />
            </StackPanel>
          </StackPanel>

          <TextBlock Margin="0,26,0,8"
                     Text="¿Cómo te sentís ahora?"
                     Foreground="#EEEEFC"
                     FontSize="16"
                     FontWeight="SemiBold" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="-10" Foreground="#BE1414" VerticalAlignment="Center" />
            <Slider x:Name="MoodSlider"
                    Grid.Column="1"
                    Margin="12,0"
                    Minimum="-10"
                    Maximum="10"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    Value="0"
                    ValueChanged="MoodSlider_OnValueChanged" />
            <TextBlock Grid.Column="2" Text="+10" Foreground="#0F9637" VerticalAlignment="Center" />
          </Grid>

          <Button Margin="0,22,0,0"
                  Padding="14,10"
                  Content="Guardar registro"
                  Click="SaveEntry_Click"
                  Background="#6C63FF"
                  Foreground="White"
                  BorderThickness="0"
                  FontWeight="Bold" />
        </StackPanel>

        <Border Grid.Column="2"
                Background="#1C1C28"
                CornerRadius="12"
                Padding="18">
          <StackPanel>
            <TextBlock Text="Resumen de hoy"
                       Foreground="#EEEEFC"
                       FontSize="18"
                       FontWeight="Bold" />
            <TextBlock x:Name="AverageTextBlock"
                       Margin="0,16,0,0"
                       Foreground="#EEEEFC"
                       FontSize="26"
                       FontWeight="Bold" />
            <TextBlock x:Name="CountTextBlock"
                       Margin="0,4,0,0"
                       Foreground="#A6A6BF"
                       FontSize="14" />

            <TextBlock Margin="0,20,0,8"
                       Text="Últimos registros"
                       Foreground="#EEEEFC"
                       FontWeight="SemiBold" />
            <ListBox x:Name="LatestEntriesListBox"
                     Height="170"
                     Background="#16161F"
                     BorderBrush="#28283A"
                     Foreground="#EEEEFC" />

            <CheckBox x:Name="AutostartCheckBox"
                      Margin="0,20,0,0"
                      Content="Iniciar automáticamente con Windows"
                      Foreground="#EEEEFC"
                      Checked="AutostartCheckBox_OnChanged"
                      Unchecked="AutostartCheckBox_OnChanged" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="2"
            Background="#16161F"
            BorderBrush="#28283A"
            BorderThickness="1"
            CornerRadius="14"
            Padding="16">
      <TabControl Background="#16161F"
                  BorderThickness="0"
                  Foreground="#EEEEFC">
        <TabItem Header="Registros">
          <DataGrid x:Name="EntriesDataGrid"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    IsReadOnly="True"
                    HeadersVisibility="Column"
                    Background="#16161F"
                    BorderThickness="0"
                    RowBackground="#16161F"
                    AlternatingRowBackground="#1C1C28"
                    Foreground="#EEEEFC">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Fecha y hora" Binding="{Binding Label}" Width="*" />
              <DataGridTextColumn Header="Valor" Binding="{Binding ValueText}" Width="140" />
            </DataGrid.Columns>
          </DataGrid>
        </TabItem>
        <TabItem Header="Diario">
          <DataGrid x:Name="DailyDataGrid"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    IsReadOnly="True"
                    HeadersVisibility="Column"
                    Background="#16161F"
                    BorderThickness="0"
                    RowBackground="#16161F"
                    AlternatingRowBackground="#1C1C28"
                    Foreground="#EEEEFC">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Día" Binding="{Binding Label}" Width="*" />
              <DataGridTextColumn Header="Promedio" Binding="{Binding ValueText}" Width="140" />
            </DataGrid.Columns>
          </DataGrid>
        </TabItem>
        <TabItem Header="Semanal">
          <DataGrid x:Name="WeeklyDataGrid"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    IsReadOnly="True"
                    HeadersVisibility="Column"
                    Background="#16161F"
                    BorderThickness="0"
                    RowBackground="#16161F"
                    AlternatingRowBackground="#1C1C28"
                    Foreground="#EEEEFC">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Semana" Binding="{Binding Label}" Width="*" />
              <DataGridTextColumn Header="Promedio" Binding="{Binding ValueText}" Width="140" />
            </DataGrid.Columns>
          </DataGrid>
        </TabItem>
        <TabItem Header="Mensual">
          <DataGrid x:Name="MonthlyDataGrid"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    IsReadOnly="True"
                    HeadersVisibility="Column"
                    Background="#16161F"
                    BorderThickness="0"
                    RowBackground="#16161F"
                    AlternatingRowBackground="#1C1C28"
                    Foreground="#EEEEFC">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Mes" Binding="{Binding Label}" Width="*" />
              <DataGridTextColumn Header="Promedio" Binding="{Binding ValueText}" Width="140" />
            </DataGrid.Columns>
          </DataGrid>
        </TabItem>
      </TabControl>
    </Border>
  </Grid>
</Window>
